# ─────────────────────────────────────────────────────────────
# Voice Story Agent — Frontend Environment Variables
#
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# NEXT_PUBLIC_* variables are inlined at build time and visible
# in the browser — never put secrets here.
# ─────────────────────────────────────────────────────────────

# Base URL of the FastAPI backend.
# Local dev:   http://localhost:8000
# Cloud Run:   https://voice-story-agent-backend-xxx-uc.a.run.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# WebSocket base URL of the FastAPI backend.
# Local dev:   ws://localhost:8000
# Cloud Run:   wss://voice-story-agent-backend-xxx-uc.a.run.app
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
