# ─────────────────────────────────────────────────────────────
# Voice Story Agent — Backend Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# You do NOT need real credentials to start the server.
# GET /health works with all values left at their defaults.
#
# When you are ready to use Google Cloud services:
#   Option A (recommended for local dev):
#     gcloud auth application-default login
#     # Then set GCP_PROJECT_ID below — no key file needed.
#
#   Option B (CI / Cloud Run / service account):
#     GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json
#     # Then set GCP_PROJECT_ID below.
# ─────────────────────────────────────────────────────────────

# ── Google Cloud Project ─────────────────────────────────────
# Your GCP project ID. Required before any Gemini / Firestore /
# GCS / TTS call is made. Leave empty to run health-check only.
GCP_PROJECT_ID=

# GCP region for Vertex AI and other regional services.
GCP_REGION=us-central1

# ── Cloud Storage ─────────────────────────────────────────────
# Name of the GCS bucket for generated illustrations and narration audio.
# Conventionally: {your-project-id}-story-assets
GCS_BUCKET_NAME=

# ── Firestore ─────────────────────────────────────────────────
# Firestore database ID. "(default)" is correct for most projects.
FIRESTORE_DATABASE=(default)

# ── Gemini Models ─────────────────────────────────────────────
# Model IDs used for story generation. These defaults are correct
# as of March 2026 — change only if you need a specific version.
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash

# ── Imagen ───────────────────────────────────────────────────
IMAGEN_MODEL=imagen-3.0-generate-001

# ── Cloud Text-to-Speech ─────────────────────────────────────
# Voice used for per-page story narration (Neural2 child-friendly voice).
TTS_VOICE_NAME=en-US-Neural2-F
TTS_LANGUAGE_CODE=en-US

# ── ADK Voice Agent ──────────────────────────────────────────
# ADK agent display name (used in logging, not in Gemini API calls).
ADK_AGENT_NAME=voice-story-agent

# ── Server ───────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# Add your Firebase App Hosting URL here when deploying.
CORS_ORIGINS=http://localhost:3000
